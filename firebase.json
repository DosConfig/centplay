{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "webgl-games",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "**/*.wasm.gz",
        "headers": [
          { "key": "Content-Encoding", "value": "gzip" },
          { "key": "Content-Type", "value": "application/wasm" }
        ]
      },
      {
        "source": "**/*.js.gz",
        "headers": [
          { "key": "Content-Encoding", "value": "gzip" },
          { "key": "Content-Type", "value": "application/javascript" }
        ]
      },
      {
        "source": "**/*.data.gz",
        "headers": [
          { "key": "Content-Encoding", "value": "gzip" },
          { "key": "Content-Type", "value": "application/octet-stream" }
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "centplay-demo",
          "appId": "1:448966282015:android:978992cb879b9a5820fe2a",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "centplay-demo",
          "appId": "1:448966282015:ios:2c2008d7c527e23220fe2a",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "centplay-demo",
          "configurations": {
            "android": "1:448966282015:android:978992cb879b9a5820fe2a",
            "ios": "1:448966282015:ios:2c2008d7c527e23220fe2a"
          }
        }
      }
    }
  }
}
